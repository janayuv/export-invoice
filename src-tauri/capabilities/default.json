{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-select",
    "sql:allow-load",
    "fs:default",
    "fs:write-all",
    "fs:scope-appconfig-recursive",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "dialog:allow-confirm",
    "updater:default"
  ]
}
