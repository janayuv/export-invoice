{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Export Invoice",
  "version": "0.5.2",
  "identifier": "com.exportinvoice.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Export Invoice",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src ipc://localhost asset://localhost https://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU3RUIyNzMwNEREMDI2NjAKUldSZ0p0Qk5NQ2ZyNSthNXVEZEdzbCtzV21ObXhjK2I2Uk5WQWIrT0U4SFhFVTY2SlIrdTRqQmsK",
      "endpoints": [
        "https://github.com/janayuv/export-invoice/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
